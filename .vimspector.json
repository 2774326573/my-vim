{
  "configurations": {
    "Python - Launch Current File": {
      "adapter": "debugpy",
      "filetypes": ["python"],
      "default": true,
      "configuration": {
        "request": "launch",
        "type": "python",
        "python": "${PythonPath:python}",
        "cwd": "${workspaceRoot}",
        "program": "${file}",
        "stopOnEntry": false,
        "console": "integratedTerminal",
        "args": []
      }
    },
    "Python - Attach": {
      "adapter": "debugpy",
      "filetypes": ["python"],
      "autoselect": false,
      "configuration": {
        "request": "attach",
        "host": "localhost",
        "port": 5678
      }
    },
    "C++ - Launch": {
      "adapter": "vscode-cpptools",
      "filetypes": ["cpp", "cc", "cxx"],
      "default": true,
      "configuration": {
        "request": "launch",
        "type": "cppdbg",
        "program": "${CppProgram:${workspaceRoot}/a.out}",
        "args": [],
        "cwd": "${workspaceRoot}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "miDebuggerPath": "${GdbPath:gdb}",
        "setupCommands": [
          {
            "description": "Enable pretty-printing for gdb",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
          }
        ]
      }
    },
    "C++ - Launch (CodeLLDB)": {
      "adapter": "CodeLLDB",
      "filetypes": ["cpp", "cc", "cxx"],
      "autoselect": false,
      "configuration": {
        "request": "launch",
        "type": "lldb",
        "program": "${CppProgram:${workspaceRoot}/a.out}",
        "args": [],
        "cwd": "${workspaceRoot}",
        "stopOnEntry": false
      }
    },
    "C - Launch": {
      "adapter": "vscode-cpptools",
      "filetypes": ["c"],
      "default": true,
      "configuration": {
        "request": "launch",
        "type": "cppdbg",
        "program": "${CppProgram:${workspaceRoot}/a.out}",
        "args": [],
        "cwd": "${workspaceRoot}",
        "environment": [],
        "externalConsole": false,
        "MIMode": "gdb",
        "miDebuggerPath": "${GdbPath:gdb}"
      }
    },
    "C - Launch (CodeLLDB)": {
      "adapter": "CodeLLDB",
      "filetypes": ["c"],
      "autoselect": false,
      "configuration": {
        "request": "launch",
        "type": "lldb",
        "program": "${CppProgram:${workspaceRoot}/a.out}",
        "args": [],
        "cwd": "${workspaceRoot}",
        "stopOnEntry": false
      }
    }
  }
}
