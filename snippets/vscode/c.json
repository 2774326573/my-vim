{
  "Main": {
    "prefix": "main",
    "body": ["int main(void) {", "  ${1:// TODO}", "  return 0;", "}"],
    "description": "C main function"
  },
  "Main With Args": {
    "prefix": "maina",
    "body": ["int main(int argc, char* argv[]) {", "  ${1:// TODO}", "  return 0;", "}"],
    "description": "C main with arguments"
  },
  "Include": {
    "prefix": "inc",
    "body": ["#include <${1:stdio.h}>"],
    "description": "Include system header"
  },
  "Printf": {
    "prefix": "printf",
    "body": ["printf(\"${1:%s}\\\\n\"${2:, value});"],
    "description": "printf call"
  },
  "Struct": {
    "prefix": "struct",
    "body": ["typedef struct ${1:Name} {", "  ${2:// fields}", "} ${1:Name};"],
    "description": "typedef struct"
  },
  "Function": {
    "prefix": "fn",
    "body": ["${1:void} ${2:function_name}(${3:void}) {", "  ${0:// TODO}", "}"],
    "description": "Function definition"
  },
  "Function Declaration": {
    "prefix": "fnd",
    "body": ["${1:void} ${2:function_name}(${3:void});"],
    "description": "Function declaration"
  },
  "Static Function": {
    "prefix": "sfn",
    "body": ["static ${1:void} ${2:function_name}(${3:void}) {", "  ${0:// TODO}", "}"],
    "description": "Static function definition"
  },
  "Header Template": {
    "prefix": "hfile",
    "body": [
      "#ifndef ${1:MODULE_H}",
      "#define ${1:MODULE_H}",
      "",
      "#ifdef __cplusplus",
      "extern \"C\" {",
      "#endif",
      "",
      "${0}",
      "",
      "#ifdef __cplusplus",
      "}",
      "#endif",
      "",
      "#endif // ${1:MODULE_H}"
    ],
    "description": "C header file template"
  },
  "For": {
    "prefix": "for",
    "body": ["for (int ${1:i} = 0; ${1:i} < ${2:count}; ++${1:i}) {", "  ${0:// code}", "}"],
    "description": "For loop"
  },
  "If": {
    "prefix": "if",
    "body": ["if (${1:condition}) {", "  ${0:// code}", "}"],
    "description": "If statement"
  },
  "Malloc": {
    "prefix": "malloc",
    "body": ["${1:type}* ${2:ptr} = (${1:type}*)malloc(sizeof(${1:type}) * ${3:count});", "if (${2:ptr} == NULL) {", "  ${0:// handle allocation failure}", "}"],
    "description": "malloc with null check"
  },
  "Header Guard": {
    "prefix": "guard",
    "body": ["#ifndef ${1:HEADER_H}", "#define ${1:HEADER_H}", "", "${0}", "", "#endif // ${1:HEADER_H}"],
    "description": "Header guard"
  }
}
