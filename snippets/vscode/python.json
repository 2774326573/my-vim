{
  "Function": {
    "prefix": "def",
    "body": ["def ${1:function_name}(${2:params}):", "    ${0:pass}"],
    "description": "Python function"
  },
  "Typed Function": {
    "prefix": "deft",
    "body": ["def ${1:function_name}(${2:param}: ${3:type}) -> ${4:return_type}:", "    ${0:pass}"],
    "description": "Typed Python function"
  },
  "Class": {
    "prefix": "class",
    "body": ["class ${1:ClassName}:", "    def __init__(self${2:, params}):", "        ${0:pass}"],
    "description": "Python class"
  },
  "Class With Methods": {
    "prefix": "classfull",
    "body": [
      "class ${1:ClassName}:",
      "    def __init__(self${2:, params}):",
      "        ${3:pass}",
      "",
      "    def ${4:method_name}(self${5:, params}):",
      "        ${0:pass}"
    ],
    "description": "Python class with constructor and method"
  },
  "Method": {
    "prefix": "method",
    "body": ["def ${1:method_name}(self${2:, params}):", "    ${0:pass}"],
    "description": "Python instance method"
  },
  "Static Method": {
    "prefix": "staticmethod",
    "body": ["@staticmethod", "def ${1:method_name}(${2:params}):", "    ${0:pass}"],
    "description": "Python static method"
  },
  "Class Method": {
    "prefix": "classmethod",
    "body": ["@classmethod", "def ${1:method_name}(cls${2:, params}):", "    ${0:pass}"],
    "description": "Python class method"
  },
  "Dataclass": {
    "prefix": "dataclass",
    "body": ["from dataclasses import dataclass", "", "@dataclass", "class ${1:ClassName}:", "    ${2:field}: ${0:type}"],
    "description": "Dataclass"
  },
  "Main": {
    "prefix": "main",
    "body": ["if __name__ == \"__main__\":", "    ${0:main()}"],
    "description": "Python main guard"
  },
  "For": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:iterable}:", "    ${0:pass}"],
    "description": "For loop"
  },
  "Try Except": {
    "prefix": "try",
    "body": ["try:", "    ${1:pass}", "except ${2:Exception} as ${3:e}:", "    ${0:pass}"],
    "description": "Try/except block"
  },
  "With Open": {
    "prefix": "open",
    "body": ["with open(${1:path}, \"${2:r}\", encoding=\"utf-8\") as ${3:f}:", "    ${0:data = ${3:f}.read()}"],
    "description": "Open file context manager"
  },
  "Argparse": {
    "prefix": "argparse",
    "body": ["import argparse", "", "parser = argparse.ArgumentParser(description=\"${1:description}\")", "parser.add_argument(\"${2:arg}\", help=\"${3:help}\")", "args = parser.parse_args()", "${0}"],
    "description": "argparse setup"
  },
  "Logging": {
    "prefix": "logging",
    "body": ["import logging", "", "logging.basicConfig(level=logging.${1:INFO}, format=\"%(levelname)s:%(name)s:%(message)s\")", "logger = logging.getLogger(__name__)", "${0}"],
    "description": "logging setup"
  },
  "List Comprehension": {
    "prefix": "list",
    "body": ["[${1:expr} for ${2:item} in ${3:items}${4: if condition}]"],
    "description": "List comprehension"
  },
  "Pytest Test": {
    "prefix": "test",
    "body": ["def test_${1:name}():", "    ${0:assert True}"],
    "description": "pytest test"
  }
}
